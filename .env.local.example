# --- Vercel AI SDK · Google Gemini provider ---
# Get your key (free tier available): https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...

# Optional: override the default model
# GEMINI_MODEL=gemini-2.5-flash

# --- Telegram Notifier (opsiyonel) ---
# Bot oluşturmak için Telegram'da @BotFather → /newbot → token al
# Chat ID öğrenmek için @userinfobot ile konuş
# Her ikisi de tanımlı değilse notifier sessizce devre dışı kalır.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
